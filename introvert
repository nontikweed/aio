#!/bin/bash
# Made By Nontikweed

clear

function endscript() {
  exit 1
}
trap endscript 2 15

# Check if Termux storage is enabled
if [ ! -d "/data/data/com.termux/files/home/storage" ]; then
  # Storage is not set up, ask the user to enable it
  termux-setup-storage
  # You might want to wait for the user to grant the permission
  read -p "Press Enter once you have granted storage permission..."
else
  echo -e "\e[1;32mTermux storage permission is already enabled.\e[0m"
fi

# Check for dig command and install dnsutils if not present
if ! command -v dig &> /dev/null; then
    echo -e "\e[1;33mdig command could not be found. Attempting to install dnsutils...\e[0m"
    
    # Update the package list
    pkg update
    
    # Install dnsutils
    pkg install -y dnsutils
    
    # Check again after attempting to install
    if ! command -v dig &> /dev/null; then
        echo -e "\e[1;31mFailed to install dnsutils. Please install it manually using 'pkg install dnsutils'.\e[0m"
        exit 1
    else
        echo -e "\e[1;32mdnsutils successfully installed.\e[0m"
    fi
fi

# Check for curl and install if not found
if ! command -v curl &> /dev/null; then
    echo -e "\e[1;33mcurl could not be found, attempting to install...\e[0m"
    pkg install -y curl
    if [ $? -ne 0 ]; then
        echo -e "\e[1;31mFailed to install curl. Please install it manually and rerun the script.\e[0m"
        exit 1
    else
        echo -e "\e[1;32mcurl has been installed successfully.\e[0m"
    fi
fi

DNS_IPS_URL="https://raw.githubusercontent.com/nontikweed/blaire69/master/dns_ips.txt"
NAMESERVERS_URL="https://raw.githubusercontent.com/nontikweed/blaire69/master/nameservers.txt"

# Delete the old DNS IP addresses file if it exists
rm -f dns_ips.txt

# Download DNS IP addresses from GitHub silently
if ! curl -s -o dns_ips.txt "${DNS_IPS_URL}" 2>/dev/null; then
    echo -e "\e[1;31mFailed to download DNS IP addresses from GitHub.\e[0m"
    exit 1
fi

# Delete the old nameservers file if it exists
rm -f nameservers.txt

# Download nameservers from GitHub silently
if ! curl -s -o nameservers.txt "${NAMESERVERS_URL}" 2>/dev/null; then
    echo -e "\e[1;31mFailed to download nameservers from GitHub.\e[0m"
    exit 1
fi

# Read the downloaded files into arrays
readarray -t DNS_IPS < dns_ips.txt
readarray -t NAME_SERVERS < nameservers.txt

clear

# Function to get custom nameserver from user
get_custom_nameserver() {
    echo -e "\033[0;35m══════════════════════════════════════════════════════════════════\033[0m"
    figlet -f slant "Introvert" | awk '{gsub(/./,"\033[3"int(rand()*3+3)"m&\033[0m")}1'
    echo -e "\033[0;35m══════════════════════════════════════════════════════════════════\033[0m"
    read -p "Enter your custom nameserver: " custom_ns
    echo -e "\033[0;35m══════════════════════════════════════════════════════════════════\033[0m"
    NAME_SERVERS+=("$custom_ns")
}

# Main menu
clear
clear
echo -e "\033[0;35m══════════════════════════════════════════════════════════════════\033[0m"
figlet -f slant "Introvert" | awk '{gsub(/./,"\033[3"int(rand()*3+3)"m&\033[0m")}1'
echo -e "\033[0;35m══════════════════════════════════════════════════════════════════\033[0m"
echo -e "\033[0;36mSelect an option:\033[0m"
echo -e "\033[0;32m1. Use default nameservers\033[0m"
echo -e "\033[0;33m2. Add custom nameserver\033[0m"
echo -e "\033[0;35m══════════════════════════════════════════════════════════════════\033[0m"
read -p "Enter your choice: " choice

case $choice in
    1)
        echo "Option 1 selected: Using default nameservers..."
        echo -e "\033[0;33mDisclaimer: Contact the admin if you wish to add your nameserver to our database.\033[0m"
        # Add any additional code here if needed for option 1
        ;;
    2)
        echo "Option 2 selected: Adding custom nameserver to the list..."
        get_custom_nameserver
        ;;
    *)
        echo "Invalid choice selected. Exiting."
        exit 1
        ;;
esac  

DIG_EXEC="DEFAULT"
CUSTOM_DIG=/data/data/com.termux/files/home/go/bin/fastdig
VER=0.3

case "${DIG_EXEC}" in
  DEFAULT|D)
    _DIG="$(command -v dig)"
    ;;
  CUSTOM|C)
    _DIG="${CUSTOM_DIG}"
    ;;
esac

if [ ! $(command -v ${_DIG}) ]; then
  printf "%b" "Dig command failed to run, please install dig(dnsutils) or check the DIG_EXEC & CUSTOM_DIG variable.\n" && exit 1
fi

# Initialize the counter
count=1

check(){
  local border_color="\e[1;37m"  # White color for a clean, elegant border
  local success_color="\e[1;32m" # Subtle green for success messages
  local fail_color="\e[1;31m"    # Soft red for failure messages
  local header_color="\e[1;34m"  # Blue color for headers, adding a touch of elegance
  local info_color="\e[1;36m"    # Cyan for informational text
  local reset_color="\e[0m"      # Reset to default terminal color
  local max_jobs=10              # Maximum number of parallel jobs

  # Determine the width for the border based on the content
  local border_width=70

  # Elegant Header
  echo -e "${border_color}┌─${header_color} Nontikweed ${border_color}─┐${reset_color}"
  
  # Results
  local job_count=0
  for T in "${DNS_IPS[@]}"; do
    for R in "${NAME_SERVERS[@]}"; do
      (
        result=$(${_DIG} @${T} ${R} +short)
        if [ -z "$result" ]; then
          STATUS="${fail_color}Failed${reset_color}"
        else
          STATUS="${success_color}Success${reset_color}"
        fi
        echo -e "${border_color}│ ${info_color}DNS IP: ${T} - NS: ${R} ${reset_color}"
        echo -e "${border_color}│ ${STATUS} ${border_color}│${reset_color}"
      ) &

      # Increment job count and wait if we've reached max jobs
      ((job_count++))
      if ((job_count >= max_jobs)); then
        wait -n
        ((job_count--))
      fi
    done
  done

  # Wait for any remaining background jobs to finish
  wait

  # Elegant Footer
  echo -e "${border_color}└─${info_color} Check Count: ${count} ${border_color}─┘${reset_color}"
}

# Self-delete the script
clear

# Main loop
while true; do
  check
  ((count++))  # Increment the counter
done

exit 0
