#!/bin/bash
# Made By Nontikweed
clear

# Check if Termux storage is enabled
if [ ! -d "/data/data/com.termux/files/home/storage" ]; then
  # Storage is not set up, ask the user to enable it
  echo -e "\e[1;33mTermux storage permission is not enabled. Enabling now...\e[0m"
  termux-setup-storage
  # You might want to wait for the user to grant the permission
  read -p "Press Enter once you have granted storage permission..."
else
  echo -e "\e[1;32mTermux storage permission is already enabled.\e[0m"
fi

# Check for dig command and install dnsutils if not present
if ! command -v dig &> /dev/null; then
    echo -e "\e[1;33mdig command could not be found. Attempting to install dnsutils...\e[0m"
    
    # Update the package list
    pkg update
    
    # Install dnsutils
    pkg install -y dnsutils
    
    # Check again after attempting to install
    if ! command -v dig &> /dev/null; then
        echo -e "\e[1;31mFailed to install dnsutils. Please install it manually using 'pkg install dnsutils'.\e[0m"
        exit 1
    else
        echo -e "\e[1;32mdnsutils successfully installed.\e[0m"
    fi
fi

function endscript() {
  exit 1
}

